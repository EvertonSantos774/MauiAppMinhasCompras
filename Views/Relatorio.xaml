<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio"
             Title="Relatório">

    <VerticalStackLayout Spacing="10" Padding="10">

        <Label Text="Data Inicial (dd/MM/yyyy):" />
        <Entry x:Name="txt_data_inicio" Placeholder="Ex: 01/03/2026" />

        <Label Text="Data Final (dd/MM/yyyy):" />
        <Entry x:Name="txt_data_fim" Placeholder="Ex: 31/03/2026" />

        <Button Text="Buscar" Clicked="BtnBuscar_Clicked"/>

        <ListView x:Name="lista_relatorio">

            <ListView.Header>
                <Grid ColumnDefinitions="100, 80, 50, 90, 100">
                    <Label Grid.Column="0" Text="Descrição" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Preço" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Qnt" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Total" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Data" FontAttributes="Bold"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="100, 80, 50, 90, 100">
                            <Label Grid.Column="0" Text="{Binding Descricao}" />
                            <Label Grid.Column="1" Text="{Binding Preco, StringFormat='{}{0:c}'}" />
                            <Label Grid.Column="2" Text="{Binding Quantidade}" />
                            <Label Grid.Column="3" Text="{Binding Total, StringFormat='{}{0:c}'}" />
                            <Label Grid.Column="4" Text="{Binding Data, StringFormat='{}{0:dd/MM/yyyy}'}" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </VerticalStackLayout>
</ContentPage>